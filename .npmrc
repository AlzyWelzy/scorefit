# next-auth@5 (beta) pins @auth/core, which declares an *optional* peer on
# nodemailer ^7. This project doesn't use Auth.js's built-in Nodemailer email
# provider (it uses the Credentials provider + src/lib/mailer.ts), so we run the
# latest nodemailer (9) and tell npm to skip that optional-peer reconciliation.
# Remove this once next-auth 5 stable widens the @auth/core nodemailer peer range.
legacy-peer-deps=true
