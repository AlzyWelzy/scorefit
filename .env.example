# Copy to .env.local (dev) or set in Vercel project env (prod).
# Neon: use the POOLED connection string (…-pooler.…). postgres.js runs with
# prepare:false so it is PgBouncer-safe.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Generate with:  npx auth secret    (or:  openssl rand -base64 33)
# Also used to encrypt TOTP 2FA secrets at rest — keep it stable & secret.
AUTH_SECRET="replace-me"

# --- SMTP (email verification OTP + password reset) ---------------------
# Any provider works (Gmail app password, Mailgun, SES, Postmark, Resend SMTP…).
# If these are unset, codes are logged to the server console (dev only).
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"                 # 465 = implicit TLS, 587 = STARTTLS
SMTP_USER="apikey-or-username"
SMTP_PASS="your-smtp-password"
EMAIL_FROM="ScoreFit <no-reply@scorefit.net>"

# --- Optional: distributed rate limiting (Upstash Redis REST) -----------
# If unset, an in-memory limiter is used (fine for a single instance / dev).
# UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="xxxx"
