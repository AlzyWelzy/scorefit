# Copy to .env.local (dev) or set in Vercel project env (prod).
# Neon: use the POOLED connection string (…-pooler.…). postgres.js runs with
# prepare:false so it is PgBouncer-safe.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Generate with:  npx auth secret    (or:  openssl rand -base64 33)
AUTH_SECRET="replace-me"
